<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
            <section name="ClienteHCS_2.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
        </sectionGroup>
    </configSections>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6"/>
    </startup>
  
  
    <system.serviceModel>
      <bindings>
        <netTcpBinding>
          <!-- Ajustado para pruebas de carga: más conexiones, timeouts más generosos, mayor pool de búferes -->
          <binding name="NetTcpBinding_IConectorBrokerWCF" 
                   closeTimeout="00:01:00" 
                   openTimeout="00:02:00" 
                   receiveTimeout="00:10:00" 
                   sendTimeout="00:02:00" 
                   transferMode="Buffered" 
                   hostNameComparisonMode="StrongWildcard" 
                   listenBacklog="100" 
                   maxBufferPoolSize="5242880" 
                   maxBufferSize="2097152" 
                   maxConnections="200" 
                   maxReceivedMessageSize="2097152">
            <security>
              <transport sslProtocols="None"/>
            </security>
          </binding>
        </netTcpBinding>
      </bindings>
      <client>
        <endpoint address="net.tcp://10.7.232.35/BNA.FU.HCS/ConectorBrokerWCF" binding="netTcpBinding" bindingConfiguration="NetTcpBinding_IConectorBrokerWCF" contract="HCS.IConectorBrokerWCF" name="NetTcpBinding_IConectorBrokerWCF">
          <identity>
            <userPrincipalName value="csdesa@DCC.DBNA.NET"/>
          </identity>
        </endpoint>
      </client>
    </system.serviceModel>
  
    <userSettings>
        <ClienteHCS_2.Properties.Settings>
            <setting name="Usuario" serializeAs="String">
                <value/>
            </setting>
            <setting name="TXFile" serializeAs="String">
                <value>TEST</value>
            </setting>
            <setting name="HCSServer" serializeAs="String">
                <value>localhost</value>
            </setting>
            <setting name="EsHexa" serializeAs="String">
                <value>False</value>
            </setting>
        </ClienteHCS_2.Properties.Settings>
    </userSettings>
</configuration>